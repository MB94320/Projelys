generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id                 Int     @id @default(autoincrement())
  projectNumber      String?
  clientName         String?
  projectManagerName String?
  titleProject       String?

  status        String?
  startDate     DateTime?
  endDate       DateTime?
  estimatedDate DateTime?

  progressPercent Int?
  riskCriticality String?

  plannedLoadDays  Int?
  consumedLoadDays Int?

  comments String?

  tasks   ProjectTask[]
  actions Action[]
  risks   Risk[]
  audits  Audit[]

  deliverables      Deliverable[]
  nonConformities   NonConformity[]
  customerIssues    CustomerIssue[]
  qualityActions    QualityAction[]
  qualityChecklists ProjectQualityChecklist[]

  openRiskCount    Int? @default(0)
  highRiskCount    Int? @default(0)
  opportunityCount Int? @default(0)

  deliverablesCount   Int   @default(0)
  deliveredCount      Int   @default(0)
  deliverablesOtdRate Float @default(0)
  deliverablesDodRate Float @default(0)
  deliverablesOqdRate Float @default(0)

  nonConformitiesCount     Int   @default(0)
  openNonConformitiesCount Int   @default(0)
  criticalNcRate           Float @default(0)
  avgNcClosureDelayDays    Float @default(0)

  previousAuditRate Float @default(0)
  currentAuditRate  Float @default(0)

  customerSatisfaction Float @default(0)
  csListening          Float @default(0)
  csPlanning           Float @default(0)
  csTechnical          Float @default(0)
  csKpiFollowup        Float @default(0)
  csRiskFollowup       Float @default(0)

  tace Float @default(0)

  otdGlobal            Float @default(0)
  oqdGlobal            Float @default(0)
  oqdPrevious          Float @default(0)
  globalConformityRate Float @default(0)

  budgetPlanned  Float @default(0)
  budgetConsumed Float @default(0)

  nonConformitiesOpenCount Int @default(0)
  auditsDoneCount          Int @default(0)

  satisfactionHistory CustomerSatisfactionHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProjectTask {
  id        Int     @id @default(autoincrement())
  projectId Int
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  name        String
  description String? @db.Text

  startDate DateTime?
  endDate   DateTime?

  plannedWorkHours  Int @default(0)
  consumedWorkHours Int @default(0)

  progressPercent Int     @default(0)
  status          String  @default("Planifiée")
  assigneeName    String?
  role            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Resource {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  role        String?
  weeklyHours Int     @default(35)
  isActive    Boolean @default(true)

  absences Absence[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Absence {
  id         Int       @id @default(autoincrement())
  resourceId Int?
  resource   Resource? @relation(fields: [resourceId], references: [id])
  type       String
  startDate  DateTime
  endDate    DateTime
  daysCount  Float
  duration   String
  comment    String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Risk {
  id        Int     @id @default(autoincrement())
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId Int

  ref        String?
  title      String
  nature     String?
  clientName String?
  category   String?

  createdAt  DateTime  @default(now())
  statusDate DateTime?
  status     String    @default("Ouvert")

  initialEvalDate        DateTime?
  initialImpact          Int?
  initialProbability     Int?
  initialScore           Int?
  initialLevel           String?
  initialPotentialImpact Float?
  initialValuatedImpact  Float?
  initialStrategy        String?

  updateEvalDate        DateTime?
  updateImpact          Int?
  updateProbability     Int?
  updateScore           Int?
  updateLevel           String?
  updatePotentialImpact Float?
  updateValuatedImpact  Float?
  updateStrategy        String?

  cause    String? @db.Text
  comments String? @db.Text

  actions Action[] @relation("RiskActions")

  updatedAt DateTime @updatedAt
}

model Action {
  id        Int      @id @default(autoincrement())
  project   Project? @relation(fields: [projectId], references: [id])
  projectId Int?
  risk      Risk?    @relation("RiskActions", fields: [riskId], references: [id])
  riskId    Int?

  title       String
  description String? @db.Text

  origin   String?
  priority String?
  owner    String?

  status   String @default("Ouverte")
  progress Int    @default(0)

  createdAt  DateTime  @default(now())
  startDate  DateTime?
  dueDate    DateTime?
  closedDate DateTime?

  efficience String?

  updatedAt DateTime @updatedAt

  qualityActions QualityAction[]
}

model Deliverable {
  id        Int     @id @default(autoincrement())
  projectId Int
  project   Project @relation(fields: [projectId], references: [id])

  reference       String? @db.VarChar(50)
  title           String
  type            String?
  description     String?
  owner           String?
  clientReference String?
  internalVersion String?
  clientVersion   String?

  contractualDate DateTime?
  revisedDate     DateTime?
  deliveredDate   DateTime?
  validatedDate   DateTime?

  progress Int?

  status             String  @default("Non commencé")
  qualityStatus      String?
  delayCause         String?
  deliveryIterations Int?
  validatedBy        String?
  comments           String?
  linkDoc            String?

  nonConformities NonConformity[]
  customerIssues  CustomerIssue[]
  qualityActions  QualityAction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NonConformity {
  id        Int     @id @default(autoincrement())
  projectId Int
  project   Project @relation(fields: [projectId], references: [id])

  reference String? @db.VarChar(50)

  deliverableId Int?
  deliverable   Deliverable? @relation(fields: [deliverableId], references: [id])

  type        String?
  origin      String?
  description String
  severity    String?
  detectedOn  DateTime?
  detectedBy  String?
  dueDate     DateTime?
  status      String    @default("Ouvert")
  closedDate  DateTime?

  rootCause        String?
  immediateAction  String?
  correctiveAction String?
  preventiveAction String?
  comments         String?
  fncUrl           String?
  eightDProgress   Int             @default(0)
  eightDComment    String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  createdBy        Int?
  qualityActions   QualityAction[]

  @@index([projectId])
  @@index([deliverableId])
  @@index([status])
  @@index([severity])
}

model CustomerIssue {
  id        Int     @id @default(autoincrement())
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId Int

  deliverableId Int?
  deliverable   Deliverable? @relation(fields: [deliverableId], references: [id])

  date            DateTime?
  customerContact String?
  channel         String?

  satisfactionScore Int?
  isMajorIssue      Boolean @default(false)

  description   String  @db.Text
  expectation   String? @db.Text
  responseGiven String? @db.Text

  status String @default("Ouverte")

  qualityActions QualityAction[]

  createdAt  DateTime  @default(now())
  closedDate DateTime?
  updatedAt  DateTime  @updatedAt
}

model QualityAction {
  id        Int     @id @default(autoincrement())
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId Int

  title       String
  description String? @db.Text
  category    String?

  owner    String?
  priority String?
  status   String  @default("Ouverte")
  progress Int     @default(0)

  startDate  DateTime?
  dueDate    DateTime?
  closedDate DateTime?

  nonConformityId Int?
  nonConformity   NonConformity? @relation(fields: [nonConformityId], references: [id])

  customerIssueId Int?
  customerIssue   CustomerIssue? @relation(fields: [customerIssueId], references: [id])

  deliverableId Int?
  deliverable   Deliverable? @relation(fields: [deliverableId], references: [id])

  globalActionId Int?
  globalAction   Action? @relation(fields: [globalActionId], references: [id])

  effectiveness String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QualityChecklistTemplateItem {
  id          Int     @id @default(autoincrement())
  clause      String
  category    String
  title       String
  expectation String  @db.Text
  helpText    String? @db.Text
  order       Int     @default(0)

  projectItems ProjectQualityChecklistItem[]
}

model ProjectQualityChecklist {
  id        Int     @id @default(autoincrement())
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId Int

  name        String?
  auditType   String?
  auditorName String?
  auditDate   DateTime?

  status String @default("Brouillon")

  items ProjectQualityChecklistItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProjectQualityChecklistItem {
  id Int @id @default(autoincrement())

  checklist   ProjectQualityChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  checklistId Int

  templateItem   QualityChecklistTemplateItem @relation(fields: [templateItemId], references: [id])
  templateItemId Int

  clause String
  title  String

  status       String  @default("Non évalué")
  comment      String? @db.Text
  evidenceLink String?

  lastUpdate DateTime @default(now())
}

model Audit {
  id  Int    @id @default(autoincrement())
  ref String @unique

  projectId Int
  project   Project @relation(fields: [projectId], references: [id])

  evaluationDate       DateTime
  lastEvaluationDate   DateTime?
  globalConformityRate Float
  previousGlobalRate   Float?

  qualityFollowUp String?
  outsourcing     String?
  xshore          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  themes                AuditTheme[]
  ncFromAuditCount      Int          @default(0)
  avgActionClosureDelay Int?
}

enum AuditArea {
  AVV
  DELIVERY
}

model AuditTheme {
  id             Int             @id @default(autoincrement())
  auditId        Int
  audit          Audit           @relation(fields: [auditId], references: [id])
  type           AuditThemeType
  area           AuditArea
  conformityRate Float?
  color          String
  questions      AuditQuestion[]
}

model AuditQuestion {
  id      Int        @id @default(autoincrement())
  themeId Int
  theme   AuditTheme @relation(fields: [themeId], references: [id])

  code    Int
  text    String
  weight  Int
  answer  AuditAnswer @default(NA)
  comment String?
}

enum AuditThemeType {
  REVUE_OPPORTUNITE
  PILOTAGE_REPONSE
  REVUE_CONTRAT
  REVUE_PROPOSITION
  GESTION_EXIGENCES
  GESTION_RISQUES_OPPORTUNITES
  PLANIFICATION
  PERFORMANCE
  REUNIONS_COMMUNICATION
  VERIFICATION_VALIDATION
  CAPITALISATION
  GESTION_CONFIGURATION
  GESTION_DOCUMENTAIRE
  SECURITE_PERSONNES
  SECURITE_DONNEES
  GESTION_RESSOURCES
  GESTION_SOUS_TRAITANCE
  GESTION_XSHORE
  GESTION_NON_CONFORMITES
  GESTION_INSATISFACTIONS
  PMP
}

enum AuditAnswer {
  OUI
  NON
  NA
}

model CustomerSatisfactionHistory {
  id             Int      @id @default(autoincrement())
  projectId      Int
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  evaluationDate DateTime
  year           Int
  month          Int
  listening      Float
  planning       Float
  technical      Float
  kpi            Float
  risk           Float
  average        Float
  createdAt      DateTime @default(now())

  @@index([projectId, year, month])
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  name         String?
  passwordHash String
  role         UserRole @default(FULL)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions            Session[]
  subscriptions       Subscription[]
  passwordResetTokens PasswordResetToken[]
}

model Session {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Subscription {
  id     Int  @id @default(autoincrement())
  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  plan         SubscriptionPlan
  billingCycle BillingCycle
  status       SubscriptionStatus @default(PENDING)

  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean   @default(false)

  stripeCustomerId     String?
  stripeSubscriptionId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([stripeCustomerId])
}

enum UserRole {
  ADMIN
  FULL
  LIMITED
}

enum SubscriptionPlan {
  LIMITED
  ESSENTIAL
  FULL
  ENTERPRISE
}

enum BillingCycle {
  TRIAL
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  TRIALING
  CANCELED
  EXPIRED
}

model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}
